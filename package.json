{
  "name": "tet-connect",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --exclude 'tests/**/*integration*.test.*' --exclude 'tests/legacy-supabase/**' --exclude 'tests/e2e-*.test.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:security": "vitest run tests/safe-redirect.test.ts tests/cron-auth.test.ts tests/ai-generate-security.test.ts tests/sw-privacy.test.ts tests/join-invite-required.test.ts tests/profile-delete-api.test.ts tests/image-process.test.ts tests/photos-upload-api.test.ts tests/posts-events-validate-api.test.ts tests/validate-api.test.ts tests/security-headers.test.ts tests/pagination.test.ts tests/protected-routes.test.ts tests/session-version.test.ts tests/delete-cascade.test.ts tests/audit-and-request-id.test.ts tests/rate-limit-concurrency.test.ts tests/admin-invariant.test.ts tests/bau-cua-concurrency.test.ts",
    "test:ci": "npm run test:unit && npm run test:security && npm run test:integration",
    "test:e2e": "vitest run tests/e2e-protected-routes.test.ts",
    "test:legacy": "vitest run tests/legacy-supabase --config vitest.legacy.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:property": "vitest run --config vitest.property.config.ts",
    "generate:secrets": "node scripts/generate-secrets.js",
    "validate:env": "node scripts/validate-env.js",
    "migration:round3:audit": "node scripts/migration-round3.js --mode=audit",
    "migration:round3:audit:strict": "node scripts/migration-round3.js --mode=audit --strict",
    "migration:round4:audit": "node scripts/migration-round3.js --mode=audit",
    "migration:round4:audit:strict": "node scripts/migration-round3.js --mode=audit --strict",
    "deploy:check": "npm run lint && npm run typecheck && npm run test:ci && npm run build && npm run validate:env"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.564.0",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.1",
    "next": "^16.2.10",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "fast-check": "^4.5.3",
    "happy-dom": "^20.6.1",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
