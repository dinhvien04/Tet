# =============================================================================
# Tết Connect — Environment variables (copy to .env.local)
# Never commit real secrets.
# =============================================================================

# --- Required (app core) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/tet-connect?retryWrites=true&w=majority
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32-min-32-chars

# Google OAuth (optional in pure credentials dev; required for Google login)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# AI (MegaLLM OpenAI-compatible) — required for /api/ai/generate
MEGALLM_API_KEY=your-megallm-api-key
MEGALLM_MODEL=your-model-name

# Cloudinary — required in production for photo upload
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-cloudinary-secret

# Cron job secret — required in production (Vercel Cron Authorization: Bearer ...)
CRON_SECRET=generate-with-crypto-random-bytes-32-hex

# --- Optional ---
# Comma-separated emails that always resolve to system admin
SYSTEM_ADMIN_EMAILS=admin@example.com

# NODE_ENV=development

# Dev-only: local photo fallback under public/uploads when Cloudinary unset
# (disabled automatically when NODE_ENV=production)
